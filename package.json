{
  "name": "web-monetization-extension",
  "description": "Web Monetization is a browser API that allows the creation of a payment stream from the user agent to the website.",
  "private": true,
  "version": "1.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/interledger/web-monetization-extension"
  },
  "scripts": {
    "build": "node ./scripts/build.ts",
    "dev": "node --watch ./scripts/build.ts --dev",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format && prettier . --check",
    "format:fix": "biome format --write && prettier . --write --log-level=warn",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report tests/e2e/playwright-report"
  },
  "dependencies": {
    "@interledger/open-payments": "^7.4.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "awilix": "^13.0.5",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.4.0",
    "http-message-signatures": "^1.0.6",
    "idb": "^8.0.3",
    "iso8601-duration": "^2.1.4",
    "loglevel": "^1.9.2",
    "posthog-js": "^1.396.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "safe-buffer": "5.2.1",
    "structured-headers": "^2.0.2",
    "tailwind-merge": "^2.6.1",
    "valtio": "^2.3.2",
    "webextension-polyfill": "^0.12.0",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@octokit/openapi-webhooks-types": "^12.1.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^8.0.0",
    "@types/chrome": "^0.2.0",
    "@types/github-script": "github:actions/github-script#v9.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "esbuild-node-builtin": "^0.1.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-style-plugin": "^1.6.3",
    "jsdom": "29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.3",
    "sade": "^1.8.1",
    "tailwindcss": "^3.4.19",
    "tinyspy": "^4.0.4",
    "totp-generator": "2.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  },
  "engines": {
    "pnpm": "^10.34.4",
    "npm": "pnpm",
    "yarn": "pnpm",
    "node": "^24.13.0"
  },
  "pnpm": {
    "overrides": {
      "safe-buffer": "5.2.1",
      "string_decoder": "1.3.0",
      "readable-stream": "2.3.8",
      "parse5": "7.3.0"
    },
    "onlyBuiltDependencies": [
      "@actions/github-script@https://codeload.github.com/actions/github-script/tar.gz/3a2844b7e9c422d3c10d287c895573f7108da1b3"
    ]
  },
  "type": "module",
  "packageManager": "pnpm@10.34.4"
}
